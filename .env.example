# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# NewsAPI (https://newsapi.org - free tier)
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage (https://www.alphavantage.co - free tier)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Bot settings
BOT_MODE=polling          # polling (local dev) or webhook (production)
WEBHOOK_URL=              # e.g. https://your-app.railway.app
PORT=8080

# Timezone for scheduler (US Eastern to align with stock market)
SCHEDULER_TIMEZONE=America/New_York

# Daily usage limit per user (Claude calls)
DAILY_USAGE_LIMIT=20
